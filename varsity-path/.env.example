# Base de données PostgreSQL (Neon — région Francfort)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/varsity_path?sslmode=require"

# Authentification (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# URL de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mailjet — Envoi transactionnel & tracking
# Créez un compte sur mailjet.com, vérifiez votre domaine, puis copiez les clés
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
# Adresse expéditeur vérifiée dans Mailjet
MAILJET_SENDER_EMAIL=recruiting@nextmoovusa.com
MAILJET_SENDER_NAME=NEXTMOOV USA Recruiting
# Webhook Mailjet : configurez l'URL https://votre-domaine.com/api/webhooks/mailjet
# Activez les événements : open, click, bounce, spam, blocked

# Stockage fichiers (Cloudflare R2 — Phase I)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=varsity-path-documents
R2_PUBLIC_URL=
